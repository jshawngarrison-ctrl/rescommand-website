# ResCommand Website — Environment Variables
# Copy to `.env.local` and fill in real values. Never commit `.env.local`.

# Public site URL (used for canonical URLs, sitemap, Open Graph)
NEXT_PUBLIC_SITE_URL=https://rescommand.com

# Google Analytics 4 — Measurement ID (e.g. G-XXXXXXXXXX)
NEXT_PUBLIC_GA_ID=

# Calendly scheduling link for the demo page inline embed
# e.g. https://calendly.com/rescommand/demo
NEXT_PUBLIC_CALENDLY_URL=

# YouTube video IDs for embeds (just the ID, not the full URL)
NEXT_PUBLIC_YOUTUBE_DEMO_ID=
NEXT_PUBLIC_YOUTUBE_WALKTHROUGH_ID=

# --- Server-only (demo booking + email notifications) ---

# Resend (or SendGrid) API key for booking confirmation emails
RESEND_API_KEY=

# Address that receives new demo-booking notifications
DEMO_NOTIFY_EMAIL=team@rescommand.com

# Google Calendar API (OAuth 2.0) — optional, alternative to Calendly
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
